            "body": {
              "mode": "raw",
              "raw": "[\r\n    {\r\n        \"title\": \"Introducción a Angular\",\r\n        \"body\": \"Angular es un framework de desarrollo web mantenido por Google que permite crear aplicaciones SPA robustas.\",\r\n        \"author\": \"Carlos Méndez\"\r\n    },\r\n    {\r\n        \"title\": \"NestJS desde cero\",\r\n        \"body\": \"NestJS es un framework de Node.js que utiliza TypeScript y sigue una arquitectura modular inspirada en Angular.\",\r\n        \"author\": \"María González\"\r\n    },\r\n    {\r\n        \"title\": \"MongoDB para principiantes\",\r\n        \"body\": \"MongoDB es una base de datos NoSQL orientada a documentos que almacena la información en formato BSON.\",\r\n        \"author\": \"Pedro Ramírez\"\r\n    },\r\n    {\r\n        \"title\": \"Signals en Angular 18\",\r\n        \"body\": \"Los signals son una nueva primitiva reactiva en Angular que permite gestionar el estado de forma más eficiente y predecible.\",\r\n        \"author\": \"Ana Jiménez\"\r\n    },\r\n    {\r\n        \"title\": \"RxJS operadores esenciales\",\r\n        \"body\": \"RxJS es una librería de programación reactiva que incluye operadores como switchMap, catchError, tap y combineLatest.\",\r\n        \"author\": \"Luis Herrera\"\r\n    },\r\n    {\r\n        \"title\": \"Docker para desarrolladores\",\r\n        \"body\": \"Docker permite empaquetar aplicaciones en contenedores para garantizar que funcionen igual en cualquier entorno de ejecución.\",\r\n        \"author\": \"Sofía Castro\"\r\n    },\r\n    {\r\n        \"title\": \"Clean Code en TypeScript\",\r\n        \"body\": \"Escribir código limpio en TypeScript implica usar nombres descriptivos, funciones pequeñas y una correcta separación de responsabilidades.\",\r\n        \"author\": \"Jorge Vargas\"\r\n    },\r\n    {\r\n        \"title\": \"Formularios reactivos en Angular\",\r\n        \"body\": \"Los formularios reactivos de Angular ofrecen un enfoque basado en código para manejar validaciones y estados del formulario de forma robusta.\",\r\n        \"author\": \"Daniela Torres\"\r\n    },\r\n    {\r\n        \"title\": \"JWT y autenticación en NestJS\",\r\n        \"body\": \"JSON Web Tokens permiten implementar autenticación stateless en APIs REST de forma segura y escalable con NestJS.\",\r\n        \"author\": \"Andrés Mora\"\r\n    },\r\n    {\r\n        \"title\": \"Mongoose schemas avanzados\",\r\n        \"body\": \"Mongoose permite definir schemas con validaciones, hooks y métodos personalizados para modelar los datos en MongoDB de forma eficiente.\",\r\n        \"author\": \"Valentina Ríos\"\r\n    },\r\n    {\r\n        \"title\": \"Arquitectura modular con NestJS\",\r\n        \"body\": \"NestJS promueve una arquitectura modular donde cada funcionalidad se encapsula en módulos independientes con sus controladores y servicios.\",\r\n        \"author\": \"Ricardo Solano\"\r\n    },\r\n    {\r\n        \"title\": \"Manejo de errores en Angular\",\r\n        \"body\": \"Angular permite interceptar errores HTTP globalmente usando HttpInterceptor para centralizar el manejo y mostrar mensajes amigables al usuario.\",\r\n        \"author\": \"Camila Navarro\"\r\n    },\r\n    {\r\n        \"title\": \"Tailwind CSS en proyectos modernos\",\r\n        \"body\": \"Tailwind CSS es un framework de utilidades que permite construir interfaces responsivas y personalizadas directamente desde el HTML sin salir del markup.\",\r\n        \"author\": \"Sebastián Flores\"\r\n    },\r\n    {\r\n        \"title\": \"Testing unitario con Jest\",\r\n        \"body\": \"Jest es el framework de testing más popular en el ecosistema JavaScript y NestJS lo incluye por defecto para escribir pruebas unitarias y de integración.\",\r\n        \"author\": \"Isabella Ruiz\"\r\n    },\r\n    {\r\n        \"title\": \"Buenas prácticas en APIs REST\",\r\n        \"body\": \"Una API REST bien diseñada usa correctamente los verbos HTTP, retorna códigos de estado apropiados y mantiene respuestas estandarizadas y consistentes.\",\r\n        \"author\": \"Felipe Mendoza\"\r\n    }\r\n]",
